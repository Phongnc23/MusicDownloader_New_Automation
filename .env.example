# ============================================================
#  Cau hinh thiet bi / ket noi - Music Downloader Automation
#  COPY file nay thanh .env roi sua cho dung may cua ban:
#      cp .env.example .env        (Git Bash / macOS / Linux)
#      copy .env.example .env      (Windows CMD)
#  File .env da bi .gitignore -> khong bi commit len repo.
# ============================================================

# --- Thiet bi (BAT BUOC sua cho dung may cua ban) ---
# Lay UDID bang lenh: adb devices
UDID=YOUR_DEVICE_UDID
DEVICE_NAME=Android Device
PLATFORM_NAME=Android
PLATFORM_VERSION=14

# --- Appium server (sua neu chay host/port khac) ---
APPIUM_SERVER_URL=http://127.0.0.1:4723
AUTOMATION_NAME=UiAutomator2

# --- App duoi test ---
APP_PACKAGE=com.musicdownloaderapp.musicdownloadappfree.mp3download
APP_ACTIVITY=com.example.blue_music_player.MainActivity
APP_NAME=Music Downloader

# --- Toi uu toc do tao session (mac dinh true tren may da chay Appium truoc do) ---
# Lan chay DAU TIEN tren may FRESH (chua tung chay Appium) -> dat SKIP_SERVER_INSTALL=false.
SKIP_SERVER_INSTALL=true
SKIP_DEVICE_INIT=true

# --- Package he thong Android (hiem khi can doi) ---
PERMISSION_PACKAGE=com.android.permissioncontroller
SETTINGS_PACKAGE=com.android.settings
INTENT_RESOLVER_PACKAGE=com.android.intentresolver
